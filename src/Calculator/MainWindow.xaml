<Window x:Class="WpfCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCalculator"
        mc:Ignorable="d"
        Title="Easy Calculator" Height="368" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <TextBox Name="resultTextBox" Grid.Row="0" TextAlignment="Right" VerticalAlignment="Center" FontSize="60"></TextBox>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button Name ="btn7" Grid.Row="1" Grid.Column="0" FontSize="25" Click="numClick">7</Button>
            <Button Name ="btn8" Grid.Row="1" Grid.Column="1" FontSize="25" Click="numClick">8</Button>
            <Button Name ="btn9" Grid.Row="1" Grid.Column="2" FontSize="25" Click="numClick">9</Button>
            <Button Name ="btn4" Grid.Row="2" Grid.Column="0" FontSize="25" Click="numClick">4</Button>
            <Button Name ="btn5" Grid.Row="2" Grid.Column="1" FontSize="25" Click="numClick">5</Button>
            <Button Name ="btn6" Grid.Row="2" Grid.Column="2" FontSize="25" Click="numClick">6</Button>
            <Button Name ="btn1" Grid.Row="3" Grid.Column="0" FontSize="25" Click="numClick">1</Button>
            <Button Name ="btn2" Grid.Row="3" Grid.Column="1" FontSize="25" Click="numClick">2</Button>
            <Button Name ="btn3" Grid.Row="3" Grid.Column="2" FontSize="25" Click="numClick">3</Button>
            <Button Name ="btnLOC" Grid.Row="4" Grid.Column="0" FontSize="25" Click="delClick">←</Button>
            <Button Name ="btn0" Grid.Row="4" Grid.Column="1" FontSize="25" Click="numClick">0</Button>
            <Button Name ="btnDot" Grid.Row="4" Grid.Column="2" FontSize="25" Click="numClick">.</Button>

            <Button Name ="btnEql" Grid.Row="4" Grid.Column="3" FontSize="25" Click="eqlClick">=</Button>
            <Button Name ="btnPlus" Grid.Row="3" Grid.Column="3" FontSize="25" Click="optClick">+</Button>
            <Button Name ="btnSub" Grid.Row="2" Grid.Column="3" FontSize="25" Click="optClick">-</Button>
            <Button Name ="btnMul" Grid.Row="1" Grid.Column="3" FontSize="25" Click="optClick">*</Button>
            <Button Name ="btnDiv" Grid.Row="0" Grid.Column="3" FontSize="25" Click="optClick">/</Button>
            <Button Name ="btnCl" Grid.Row="0" Grid.Column="2" FontSize="25" Click="resetClick">C</Button>
            <Button Name ="btnRBr" Grid.Row="0" Grid.Column="1" FontSize="25" Click="brtClick">)</Button>
            <Button Name ="btnLBr" Grid.Row="0" Grid.Column="0" FontSize="25" Click="brtClick">(</Button>
            
        </Grid>
    </Grid>
</Window>
