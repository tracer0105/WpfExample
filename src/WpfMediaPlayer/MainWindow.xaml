<Window x:Class="WpfMediaPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="简易媒体播放器" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 视频显示区域 -->
        <MediaElement x:Name="MediaPlayer" 
                      Grid.Row="0" 
                      LoadedBehavior="Manual" 
                      UnloadedBehavior="Stop"
                      MediaOpened="MediaPlayer_MediaOpened"
                      MediaEnded="MediaPlayer_MediaEnded"/>

        <!-- 控制栏第一行：播放控制按钮 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button x:Name="BtnOpen" Content="打开文件" Click="BtnOpen_Click" Margin="5" Padding="10,5"/>
            <Button x:Name="BtnPlay" Content="播放" Click="BtnPlay_Click" Margin="5" Padding="10,5"/>
            <Button x:Name="BtnPause" Content="暂停" Click="BtnPause_Click" Margin="5" Padding="10,5"/>
            <Button x:Name="BtnStop" Content="停止" Click="BtnStop_Click" Margin="5" Padding="10,5"/>
        </StackPanel>

        <!-- 进度条和时间显示 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="ProgressSlider" 
                    Grid.Column="0" 
                    Minimum="0" 
                    Maximum="100" 
                    Value="0"
                    ToolTip="拖动调节进度"
                    primitives:Thumb.DragStarted="ProgressSlider_DragStarted"
                    primitives:Thumb.DragCompleted="ProgressSlider_DragCompleted"/>
            <TextBlock x:Name="CurrentTimeLabel" Grid.Column="1" Text="00:00" Margin="5,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="TotalTimeLabel" Grid.Column="2" Text="/ 00:00" Margin="0,0,5,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- 音量控制 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button x:Name="BtnMute" Content="静音" Click="BtnMute_Click" Margin="5" Padding="10,5"/>
            <Slider x:Name="VolumeSlider" 
                    Width="100" 
                    Minimum="0" 
                    Maximum="1" 
                    Value="0.5" 
                    ValueChanged="VolumeSlider_ValueChanged"
                    Margin="5"/>
            <TextBlock x:Name="VolumePercent" Text="50%" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>